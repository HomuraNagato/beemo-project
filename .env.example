
# --------------------    services     -------------------- #
LLM_ADDR=eve-vllm:5014
VISION_ADDR=eve-vision:5016
UI_ADDR=eve-ui:5017
TTS_ADDR=eve-tts:5018
ASR_ADDR=eve-asr:5019
WAKEWORD_ADDR=eve-wakeword:5020

LLM_HTTP_URL=http://eve-vllm:5014/v1/chat/completions
DECISION_GRAMMAR_PATH=scripts/grammars/tool_list.gbnf

# -------------------- --------------- -------------------- #

# --------------------   LLM models    -------------------- #

# reasoning vllm server
MODEL_DIR=/models
REASONING_MODEL=Qwen3.5-2B
#REASONING_MODEL=Nvidia-Nemotron-3-Nano-4B-FP8
REASONING_PORT=5014
REASONING_HOST=0.0.0.0
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.90  # used only when VLLM_KV_CACHE_MEMORY_BYTES is unset
VLLM_MAX_MODEL_LEN=2048  # 8192
VLLM_CPU_OFFLOAD_GB=0  # 6
VLLM_SWAP_SPACE_GB=0   # 8
VLLM_KV_CACHE_MEMORY_BYTES=4G
VLLM_REASONING_PARSER=qwen3
VLLM_DEFAULT_CHAT_TEMPLATE_KWARGS={"enable_thinking": false}

# orpheus-cpp-tts for tokenization
ORPHEUS_API_PORT=5024
ORPHEUS_API_URL=http://llama-cpp-tts:${ORPHEUS_API_PORT}/v1/completions # with Orpheus-3
ORPHEUS_API_TIMEOUT=120 # You should scale this value based on max tokens and your inference speed

# -------------------- --------------- -------------------- #

# -------------------- speech / voice --------------------- #

ASR_HOST=0.0.0.0
ASR_PORT=5019
ASR_MODEL=small.en
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_LANGUAGE=en
ASR_DOWNLOAD_ROOT=/models/faster-whisper
ASR_VAD_FILTER=false
ASR_BEAM_SIZE=1

WAKEWORD_HOST=0.0.0.0
WAKEWORD_PORT=5020
WAKEWORD_SESSION_ID=voice-loop
WAKEWORD_DETECTION_MODE=hybrid
WAKEWORD_PHRASES=hey beemo,hey bmo,okay beemo,ok beemo
WAKEWORD_MODEL_PATH=/models/wakeword/wakeword.onnx
WAKEWORD_THRESHOLD=0.5
WAKEWORD_VAD_THRESHOLD=0.0
WAKEWORD_DEBOUNCE_SECS=2
WAKEWORD_OPENWAKEWORD_FRAME_MS=80
WAKEWORD_SAMPLE_RATE_HZ=16000
WAKEWORD_FRAME_MS=100
WAKEWORD_PREROLL_MS=300
WAKEWORD_MIN_SPEECH_MS=400
WAKEWORD_SILENCE_MS=1200
WAKEWORD_MAX_UTTERANCE_MS=10000
WAKEWORD_SPEECH_RMS_THRESHOLD=700
WAKEWORD_FOLLOWUP_ENABLED=true
WAKEWORD_FOLLOWUP_TIMEOUT_SECS=12
WAKEWORD_FOLLOWUP_MAX_TURNS=4
WAKEWORD_ASR_TIMEOUT_SECS=60
WAKEWORD_ORCH_TIMEOUT_SECS=120

PULSE_SOCKET_PATH=/mnt/wslg/PulseServer
PULSE_SERVER=unix:/tmp/pulse/native
PULSE_SOURCE=default

# -------------------- --------------- -------------------- #


# -------------------- Orpheus-FastAPI -------------------- #

# Web UI settings (keep in mind that the web UI is not secure and should not be exposed to the internet)
ORPHEUS_PORT=5023
ORPHEUS_HOST=0.0.0.0

# Generation parameters
ORPHEUS_MAX_TOKENS=8192 # If you want longer completions, increase this value
ORPHEUS_TEMPERATURE=0.6
ORPHEUS_TOP_P=0.9
# Repetition penalty is now hardcoded to 1.1 for stability (this is a model constraint) - this setting is no longer used
# ORPHEUS_REPETITION_PENALTY=1.1
ORPHEUS_SAMPLE_RATE=24000
ORPHEUS_MODEL_NAME=Orpheus-3b-FT-Q8_0.gguf # Model name sent to inference server (Q2_K, Q4_K_M, or Q8_0 variants)
#ORPHEUS_MODEL_NAME=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf

# -------------------- --------------- -------------------- #
